    "@red-hat-developer-hub/plugin-utils": "workspace:^",
    "@scalprum/react-core": "0.9.5",
    "lodash": "^4.18.1",
    "react": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "@backstage/app-defaults": "^1.7.7",
